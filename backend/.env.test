# Configuration for automated testing
APP_ENV=development
LOG_LEVEL=DEBUG

# Use an in-memory database for speed and isolation during tests
DB_PATH=:memory:

# Lower thresholds to trigger error states faster in tests
LOOP_THRESHOLD=2

# Minimal concurrency for deterministic test results
CONCURRENCY_LIMIT=1

PROMETHEUS_ENABLED=False
CORS_ORIGINS=["*"]