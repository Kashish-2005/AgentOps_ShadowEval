# Application Environment (development, staging, or production)
APP_ENV=development

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Path to the SQLite database file
DB_PATH=/data/shadoweval.db

# Maximum number of times an agent can call the same tool before an InfiniteLoopError is raised
LOOP_THRESHOLD=4

# Maximum number of concurrent persona runs allowed in the traffic engine
CONCURRENCY_LIMIT=3

# Toggle for Prometheus metrics exporting
PROMETHEUS_ENABLED=True

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]